    "googleapis": "^171.4.0",
    "ical-generator": "^10.2.0",
    "nodemailer": "^9.0.1",
    "sitemap": "^9.0.1",
    "utf8": "^3.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/nodemailer": "^8.0.0",
    "@types/utf8": "^3.0.3",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^10.3.0",
    "eslint-config-google": "^0.14.0",
    "eslint-plugin-import": "^2.32.0",
    "firebase-functions-test": "^3.4.1",
    "globals": "^17.6.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
